[
  {
    "id": "saas_startup",
    "category": "SaaS",
    "title": "Software as a Service (SaaS)",
    "framework": "Lean Startup",
    "description": "Cloud-based software delivered on subscription basis with recurring revenue model.",
    "stages": [
      {
        "name": "Idea Validation",
        "duration": "2-4 weeks",
        "steps": [
          "Identify target market pain points",
          "Conduct 20+ customer interviews",
          "Create landing page with waitlist",
          "Build minimum viable product (MVP)",
          "Test with 10-20 early adopters"
        ],
        "resources": [
          {"title": "The Lean Startup by Eric Ries", "url": "https://amzn.to/3xyz", "type": "book"},
          {"title": "Y Combinator Startup School", "url": "https://www.startupschool.org/", "type": "course"}
        ],
        "common_pitfalls": ["Building without customer validation", "Feature creep", "Ignoring competition"]
      },
      {
        "name": "Product Development",
        "duration": "3-6 months",
        "steps": [
          "Define core features based on feedback",
          "Build MVP with essential functionality",
          "Implement analytics and user tracking",
          "Conduct beta testing with 50-100 users",
          "Iterate based on user feedback"
        ],
        "resources": [
          {"title": "Product School - Product Management", "url": "https://productschool.com/", "type": "course"},
          {"title": "Mixpanel Analytics Guide", "url": "https://mixpanel.com/", "type": "tool"}
        ],
        "common_pitfalls": ["Over-engineering", "Ignoring technical debt", "Slow iteration cycles"]
      },
      {
        "name": "Go-to-Market",
        "duration": "2-3 months",
        "steps": [
          "Define pricing strategy",
          "Build marketing funnel",
          "Launch content marketing",
          "Implement referral program",
          "Establish customer success process"
        ],
        "resources": [
          {"title": "HubSpot Academy - Inbound Marketing", "url": "https://academy.hubspot.com/", "type": "course"},
          {"title": "Stripe Atlas - Business Setup", "url": "https://stripe.com/atlas", "type": "tool"}
        ],
        "common_pitfalls": ["Wrong pricing model", "Poor onboarding experience", "Ignoring customer retention"]
      },
      {
        "name": "Growth & Scale",
        "duration": "6-12 months",
        "steps": [
          "Optimize conversion funnel",
          "Expand feature set",
          "Build partnerships",
          "Scale infrastructure",
          "Hire key team members"
        ],
        "resources": [
          {"title": "Blitzscaling by Reid Hoffman", "url": "https://amzn.to/3abc", "type": "book"},
          {"title": "AWS Startup Programs", "url": "https://aws.amazon.com/startups/", "type": "program"}
        ],
        "common_pitfalls": ["Premature scaling", "Cash flow mismanagement", "Losing product-market fit"]
      }
    ],
    "funding_options": ["Bootstrapping", "Angel Investment", "Seed Round", "Series A"],
    "key_metrics": ["MRR (Monthly Recurring Revenue)", "Churn Rate", "CAC (Customer Acquisition Cost)", "LTV (Lifetime Value)", "NPS (Net Promoter Score)"],
    "case_studies": [
      {
        "company": "Slack",
        "summary": "Started as internal tool, pivoted to team communication, reached $1B ARR in 8 years",
        "key_learnings": ["Product-led growth", "Freemium model", "Viral adoption"]
      },
      {
        "company": "Notion",
        "summary": "All-in-one workspace, grew through community and word-of-mouth",
        "key_learnings": ["Community building", "Template ecosystem", "User-generated content"]
      }
    ]
  },
